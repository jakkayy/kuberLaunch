apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ .Slug }}
  namespace: argocd
spec:
  project: default
  source:
    repoURL: https://github.com/org/{{ .Slug }}
    targetRevision: HEAD
    path: helm
    helm:
      valueFiles:
        - values.yaml
  destination:
    server: https://kubernetes.default.svc
    namespace: {{ .Slug }}-dev
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
