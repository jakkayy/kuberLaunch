name: CI

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main]
  workflow_dispatch:

env:
  REGISTRY: ghcr.io
  IMAGE_NAME: ${{ "{{" }} github.repository_owner {{ "}}" }}/{{ .Slug }}

jobs:
  build-and-push:
    runs-on: ubuntu-latest
    permissions:
      contents: write
      packages: write

    steps:
      - uses: actions/checkout@v4

      - name: Log in to GHCR
        uses: docker/login-action@v3
        with:
          registry: ${{ "{{" }} env.REGISTRY {{ "}}" }}
          username: ${{ "{{" }} github.actor {{ "}}" }}
          password: ${{ "{{" }} secrets.GITHUB_TOKEN {{ "}}" }}

      - name: Extract metadata
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: ${{ "{{" }} env.REGISTRY {{ "}}" }}/${{ "{{" }} env.IMAGE_NAME {{ "}}" }}
          tags: |
            type=sha,prefix=sha-
            type=ref,event=branch
            type=raw,value=latest,enable=${{ "{{" }} github.ref == 'refs/heads/main' {{ "}}" }}

      - name: Build and push
        uses: docker/build-push-action@v5
        with:
          context: .
          push: true
          tags: ${{ "{{" }} steps.meta.outputs.tags {{ "}}" }}
          labels: ${{ "{{" }} steps.meta.outputs.labels {{ "}}" }}

      - name: Update helm values
        if: github.ref == 'refs/heads/main'
        run: |
          IMAGE_TAG=$(echo "${{ "{{" }} github.sha {{ "}}" }}" | cut -c1-7)
          sed -i "s|tag: .*|tag: \"sha-${IMAGE_TAG}\"|" helm/values.yaml
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add helm/values.yaml
          git commit -m "chore: update image tag to sha-${IMAGE_TAG} [skip ci]"
          git push

      - name: Create GHCR pull secret in cluster
        if: github.ref == 'refs/heads/main' && secrets.KUBECONFIG != ''
        env:
          KUBECONFIG_DATA: ${{ "{{" }} secrets.KUBECONFIG {{ "}}" }}
        run: |
          mkdir -p ~/.kube
          echo "$KUBECONFIG_DATA" | base64 -d > ~/.kube/config
          kubectl create namespace {{ .Slug }}-dev --dry-run=client -o yaml | kubectl apply -f -
          kubectl create secret docker-registry ghcr-secret \
            --docker-server=ghcr.io \
            --docker-username=${{ "{{" }} github.actor {{ "}}" }} \
            --docker-password=${{ "{{" }} secrets.GITHUB_TOKEN {{ "}}" }} \
            --namespace={{ .Slug }}-dev \
            --dry-run=client -o yaml | kubectl apply -f -
